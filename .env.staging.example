# ─────────────────────────────────────────────────────────────
# Ingobyi Academy — staging / in-house test environment
# Copy to project root:  cp .env.staging.example .env
# Then edit PUBLIC_URL to your server IP or hostname.
# ─────────────────────────────────────────────────────────────

# Public URL users open in the browser (no trailing slash)
# Examples: http://192.168.1.50  http://staging.ingobyi.local
PUBLIC_URL=http://localhost

# Port nginx listens on (default 80)
HTTP_PORT=80

# Show demo login hint on sign-in page (set false before public launch)
SHOW_DEMO_CREDENTIALS=true

# ── Database (postgres service) ──
POSTGRES_USER=ingobyi
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-16
POSTGRES_DB=ingobyi_db

# ── App ──
NODE_ENV=staging
FRONTEND_URL=http://localhost

# Generate secrets: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32-min-16-chars
REFRESH_SECRET=replace-with-another-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# Cookies — leave COOKIE_DOMAIN empty when using IP address
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Staging: enable API docs for testers. Disable before public production.
ENABLE_SWAGGER=true

# Set true only on first deploy to load demo users (password123)
RUN_SEED=false

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=200

# ── Email (optional — OTP logged to API console if unset) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ingobyi.com

# ── Cloudinary (optional — image uploads disabled if unset) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google OAuth (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback
