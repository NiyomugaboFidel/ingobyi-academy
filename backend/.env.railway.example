# Railway — backend API service variables
# Paste into Railway → backend service → Variables

NODE_ENV=production

# Set after frontend is deployed (must match exactly, with https://)
FRONTEND_URL=https://your-frontend.up.railway.app

# Link to Postgres plugin
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Generate: openssl rand -hex 32
JWT_SECRET=
REFRESH_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# HTTPS on Railway
COOKIE_SECURE=true
COOKIE_DOMAIN=

# Staging: true. Production: false
ENABLE_SWAGGER=true
RUN_SEED=false

THROTTLE_TTL=60
THROTTLE_LIMIT=200

# Optional
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ingobyi.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-api.up.railway.app/api/auth/google/callback
