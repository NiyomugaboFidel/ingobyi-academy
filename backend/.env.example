# App (development | staging | production | test)
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
ENABLE_SWAGGER=true
RUN_SEED=false

# Database
DATABASE_URL=postgresql://ingobyi:ingobyi_pass@localhost:5432/ingobyi_db

# JWT
JWT_SECRET=your-secret-here-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_SECRET=your-refresh-secret-change-in-production
REFRESH_EXPIRES_IN=7d

# Cookie (leave COOKIE_DOMAIN empty when using IP address)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ingobyi.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
